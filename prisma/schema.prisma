generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "mysql"
  url      = env("DATABASE_URL")
}

model User {
  id                String    @id @default(cuid())
  email             String    @unique
  emailVerified     DateTime?
  name              String?
  phone             String?
  password          String
  image             String?
  role              Role      @default(USER)
  isActive          Boolean   @default(true)
  twoFactorEnabled  Boolean   @default(false)
  referralCode      String    @unique
  referredById      String?
  referredBy        User?     @relation("Referrals", fields: [referredById], references: [id])
  referrals         User[]    @relation("Referrals")
  goldBalance       Decimal   @default(0) @db.Decimal(18, 6)
  cashBalance       Decimal   @default(0) @db.Decimal(18, 2)
  createdAt         DateTime  @default(now())
  updatedAt         DateTime  @updatedAt

  // Relations
  transactions      Transaction[]
  orders            Order[]
  withdrawals       Withdrawal[]
  referralEarnings  ReferralEarning[]
  assistantSettings AssistantSettings?
  accounts          Account[]
  sessions          Session[]

  @@index([referredById])
  @@index([referralCode])
  @@index([email])
}

model Account {
  id                String  @id @default(cuid())
  userId            String
  type              String
  provider          String
  providerAccountId String
  refresh_token     String? @db.Text
  access_token      String? @db.Text
  expires_at        Int?
  token_type        String?
  scope             String?
  id_token          String? @db.Text
  session_state     String?

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@unique([provider, providerAccountId])
  @@index([userId])
}

model Session {
  id           String   @id @default(cuid())
  sessionToken String   @unique
  userId       String
  expires      DateTime
  user         User     @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@index([userId])
}

model VerificationToken {
  identifier String
  token      String   @unique
  expires    DateTime

  @@unique([identifier, token])
}

model Transaction {
  id              String          @id @default(cuid())
  userId          String
  user            User            @relation(fields: [userId], references: [id], onDelete: Cascade)
  type            TransactionType
  amount          Decimal         @db.Decimal(18, 6)
  pricePerGram    Decimal         @db.Decimal(18, 2)
  totalValue      Decimal         @db.Decimal(18, 2)
  fee             Decimal         @default(0) @db.Decimal(18, 2)
  status          TransactionStatus @default(PENDING)
  isAssistantTrade Boolean        @default(false)
  createdAt       DateTime        @default(now())
  updatedAt       DateTime        @updatedAt

  @@index([userId])
  @@index([type])
  @@index([status])
  @@index([createdAt])
}

model GoldPrice {
  id          String   @id @default(cuid())
  pricePerGram Decimal  @db.Decimal(18, 2)
  currency    String   @default("IDR")
  source      String   @default("API")
  createdAt   DateTime @default(now())

  @@index([createdAt])
}

model Product {
  id          String   @id @default(cuid())
  name        String
  description String   @db.Text
  category    ProductCategory
  weight      Decimal  @db.Decimal(10, 3)
  purity      String   @default("24K")
  price       Decimal  @db.Decimal(18, 2)
  stock       Int      @default(0)
  images      Json
  isActive    Boolean  @default(true)
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt

  orderItems  OrderItem[]

  @@index([category])
  @@index([isActive])
}

model Order {
  id              String      @id @default(cuid())
  userId          String
  user            User        @relation(fields: [userId], references: [id], onDelete: Cascade)
  orderNumber     String      @unique
  status          OrderStatus @default(PENDING)
  subtotal        Decimal     @db.Decimal(18, 2)
  shippingCost    Decimal     @db.Decimal(18, 2)
  total           Decimal     @db.Decimal(18, 2)
  shippingAddress Json
  paymentMethod   String
  paymentStatus   PaymentStatus @default(PENDING)
  trackingNumber  String?
  notes           String?     @db.Text
  createdAt       DateTime    @default(now())
  updatedAt       DateTime    @updatedAt

  items           OrderItem[]

  @@index([userId])
  @@index([status])
  @@index([orderNumber])
}

model OrderItem {
  id          String  @id @default(cuid())
  orderId     String
  order       Order   @relation(fields: [orderId], references: [id], onDelete: Cascade)
  productId   String
  product     Product @relation(fields: [productId], references: [id])
  quantity    Int
  price       Decimal @db.Decimal(18, 2)
  weight      Decimal @db.Decimal(10, 3)

  @@index([orderId])
  @@index([productId])
}

model Withdrawal {
  id              String           @id @default(cuid())
  userId          String
  user            User             @relation(fields: [userId], references: [id], onDelete: Cascade)
  type            WithdrawalType
  amount          Decimal          @db.Decimal(18, 6)
  status          WithdrawalStatus @default(PENDING)
  bankName        String?
  accountNumber   String?
  accountName     String?
  physicalAddress Json?
  adminNotes      String?          @db.Text
  processedAt     DateTime?
  createdAt       DateTime         @default(now())
  updatedAt       DateTime         @updatedAt

  @@index([userId])
  @@index([status])
  @@index([createdAt])
}

model ReferralEarning {
  id              String   @id @default(cuid())
  userId          String
  user            User     @relation(fields: [userId], references: [id], onDelete: Cascade)
  fromUserId      String
  level           Int
  transactionType String
  amount          Decimal  @db.Decimal(18, 2)
  createdAt       DateTime @default(now())

  @@index([userId])
  @@index([fromUserId])
  @@index([createdAt])
}

model AssistantSettings {
  id              String   @id @default(cuid())
  userId          String   @unique
  user            User     @relation(fields: [userId], references: [id], onDelete: Cascade)
  isEnabled       Boolean  @default(false)
  maxTradeAmount  Decimal  @default(0) @db.Decimal(18, 2)
  riskLevel       RiskLevel @default(MEDIUM)
  autoReinvest    Boolean  @default(false)
  createdAt       DateTime @default(now())
  updatedAt       DateTime @updatedAt
}

model SystemSettings {
  id                    String   @id @default(cuid())
  buyFeePercent         Decimal  @default(0.5) @db.Decimal(5, 2)
  sellFeePercent        Decimal  @default(0.5) @db.Decimal(5, 2)
  minWithdrawalGold     Decimal  @default(1) @db.Decimal(18, 6)
  minWithdrawalCash     Decimal  @default(100000) @db.Decimal(18, 2)
  referralLevel1Percent Decimal  @default(5) @db.Decimal(5, 2)
  referralLevel2Percent Decimal  @default(3) @db.Decimal(5, 2)
  referralLevel3Percent Decimal  @default(2) @db.Decimal(5, 2)
  assistantFeePercent   Decimal  @default(10) @db.Decimal(5, 2)
  createdAt             DateTime @default(now())
  updatedAt             DateTime @updatedAt
}

// Enums
enum Role {
  USER
  ADMIN
  SUPER_ADMIN
}

enum TransactionType {
  BUY
  SELL
  DEPOSIT
  WITHDRAWAL
  REFERRAL_BONUS
  ASSISTANT_PROFIT
}

enum TransactionStatus {
  PENDING
  COMPLETED
  FAILED
  CANCELLED
}

enum ProductCategory {
  GOLD_BAR
  GOLD_COIN
  JEWELRY
  GIFT_SET
}

enum OrderStatus {
  PENDING
  CONFIRMED
  PROCESSING
  SHIPPED
  DELIVERED
  CANCELLED
}

enum PaymentStatus {
  PENDING
  PAID
  FAILED
  REFUNDED
}

enum WithdrawalType {
  CASH
  PHYSICAL_GOLD
}

enum WithdrawalStatus {
  PENDING
  APPROVED
  PROCESSING
  COMPLETED
  REJECTED
}

enum RiskLevel {
  LOW
  MEDIUM
  HIGH
}
